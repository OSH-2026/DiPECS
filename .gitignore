# --- [ 1. 编译产物 ] ---
# 过滤所有编译产物（这是最大的垃圾来源）
target/
# 过滤 Cargo 产生的备份文件
**/*.rs.bk
# 如果你使用了特定的集成测试输出
tests/*.log
# Rust/Cargo 补充
node_modules/
.venv/
dist/

# Python / uv
__pycache__/
*.pyc
*.pyo

# --- [ 2. IDE 与开发环境 ] ---
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (CLion/IntelliJ)
.idea/
*.iml

# Vim/Emacs
*~
*.swp
.DS_Store

# --- [ 3. Android & NDK 交叉编译 ] ---
# 过滤 Android Studio 产生的本地配置文件
**/build/
.gradle/
.cxx/
local.properties
.externalNativeBuild/
# 所有的 .so 动态库（除非是预编译的第三方库）
*.so

# --- [ 4. 离线数据与日志 (核心项) ] ---
# 过滤巨大的原始采集数据（建议存放在专门的数据服务器或通过 LFS 管理）
data/traces/*.raw
data/traces/*.bin
# 过滤运行时的临时评估日志
data/evaluation/*.log
# replay 审计流明细:由 trace + aios-cli replay 可确定性重生成,审计哈希已记入 .md
data/evaluation/*.audit
logs/
site/
*.out

# --- [ 5. 密钥与隐私 ] ---
# 严禁将任何密钥、Token 提交到 Git
.env
.env.*
!.env.example
*.pem
*.key
*.p12

# --- [ 6. 系统与杂项 ] ---
Thumbs.db
desktop.ini
.DS_Store
temp/
*.tmp
*.temp
*.bak
*.local
.codex
.gitignore
CLAUDE.md
.claude/
/mytyp/template/
/othergroups/
/wxzprivate/
*.patch

# --- [ 7. Lab4 大模型与第三方构建产物 ] ---
# GGUF/权重文件通常数百 MB 到数 GB，不直接提交 Git。
lab4/data/models/*.gguf
lab4/data/models/*.bin
lab4/data/models/*.safetensors
lab4/data/models/*.pt
lab4/data/models/*.pth
!lab4/data/models/placeholder.model
!lab4/data/models/README.md

# Lab4 的实验结果体积较小，是报告可复现性的评分证据，随代码提交。

# llama.cpp 作为 submodule 指针提交，构建产物不提交。
lab4/third_party/llama.cpp/build*/
lab4/third_party/llama.cpp/.cache/
