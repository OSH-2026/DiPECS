# 默认：所有被 Git 识别为文本的文件统一使用 LF，避免 CRLF 混入库。
# 下面的具体规则（LFS、gradlew.bat 等）会覆盖本行。
* text=auto eol=lf

# --- [ 1. 静态参考资料 (References) ] ---
*.pdf filter=lfs diff=lfs merge=lfs -text
# --- [ 2. 轨迹数据 (Traces) ] ---
data/traces/**/*.bin filter=lfs diff=lfs merge=lfs -text
data/traces/**/*.pb filter=lfs diff=lfs merge=lfs -text
data/traces/**/*.parquet filter=lfs diff=lfs merge=lfs -text
# 如果 JSON 文件被识别为大型数据集（如超过 2MB），也建议强制 LFS
# data/traces/**/*.json filter=lfs diff=lfs merge=lfs -text
# --- [ 3. 第三方预编译库 ] ---
# 仅当源码编译太慢或不可用时
**/*.so filter=lfs diff=lfs merge=lfs -text
**/*.a filter=lfs diff=lfs merge=lfs -text
# --- [ 4. 文档素材 ] ---
# 演示录屏、图标、幻灯片图片和高精素材
docs/**/*.mp4 filter=lfs diff=lfs merge=lfs -text
docs/**/*.mov filter=lfs diff=lfs merge=lfs -text
docs/**/*.png filter=lfs diff=lfs merge=lfs -text
docs/**/*.jpg filter=lfs diff=lfs merge=lfs -text
docs/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
docs/**/*.webp filter=lfs diff=lfs merge=lfs -text
docs/**/*.gif filter=lfs diff=lfs merge=lfs -text
*.pptx filter=lfs diff=lfs merge=lfs -text
# --- [ 5. 严禁 LFS (White List) ] ---
# 显式声明：所有的代码和配置文件严禁进入 LFS
*.rs text eol=lf
*.toml text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.jsonl filter=lfs diff=lfs merge=lfs -text
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.sh text eol=lf
*.tex text eol=lf
# --- [ 6. Gradle / Android ] ---
gradlew text eol=lf
gradlew.bat text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
gradle.properties text eol=lf
gradle-wrapper.properties text eol=lf
*.xml text eol=lf
