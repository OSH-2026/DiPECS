# DiPECS cloud LLM backend
# Copy this file to `.env` for local development.
# Source it before running DiPECS in WSL or Linux: `set -a; source .env; set +a`

DIPECS_CLOUD_LLM_ENABLED=false

# Provider preset: deepseek | qwen | generic
# - deepseek: defaults endpoint to https://api.deepseek.com/chat/completions
# - qwen: defaults endpoint to https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DIPECS_CLOUD_LLM_PROVIDER=deepseek

# DeepSeek is the default preset.
# For generic mode, fill both endpoint and model manually.
# For deepseek/qwen, you can leave these blank and use the provider defaults.
DIPECS_CLOUD_LLM_ENDPOINT=
DIPECS_CLOUD_LLM_MODEL=

# Generic key variable. You can also use provider-native aliases:
# - DeepSeek: DEEPSEEK_API_KEY
# - Qwen/DashScope: DASHSCOPE_API_KEY
DIPECS_CLOUD_LLM_API_KEY=

# Optional tuning
DIPECS_CLOUD_LLM_TIMEOUT_SECS=15
DIPECS_CLOUD_LLM_TEMPERATURE=0.1
DIPECS_CLOUD_LLM_ENABLE_THINKING=
DIPECS_CLOUD_LLM_REASONING_EFFORT=

# Android action bridge forwarding from aios-action.
# Token is generated by the Android collector app and shown in its status panel.
DIPECS_ANDROID_ACTION_BRIDGE_ENABLED=false
DIPECS_ANDROID_ACTION_BRIDGE_HOST=127.0.0.1
DIPECS_ANDROID_ACTION_BRIDGE_PORT=46321
DIPECS_ANDROID_ACTION_BRIDGE_TOKEN=

# Example preset: DeepSeek
# DIPECS_CLOUD_LLM_ENABLED=true
# DIPECS_CLOUD_LLM_PROVIDER=deepseek
# DIPECS_CLOUD_LLM_MODEL=deepseek-v4-flash
# DEEPSEEK_API_KEY=sk-...

# Example preset: Qwen
# DIPECS_CLOUD_LLM_ENABLED=true
# DIPECS_CLOUD_LLM_PROVIDER=qwen
# DIPECS_CLOUD_LLM_MODEL=qwen-plus
# DASHSCOPE_API_KEY=sk-...
